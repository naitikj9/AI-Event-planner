# Copy this file to ".env" and fill in your real key.
# The .env file is gitignored and must NEVER be committed.

# ---- LLM provider ----
# Which provider to use: "openai" (default). Code is written to be switchable.
LLM_PROVIDER=openai

# Your OpenAI API key (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-key-here

# Models (defaults are cheap + capable; override if you like)
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ---- Optional: LangSmith tracing (leave blank to use local logs instead) ----
# Get a key at https://smith.langchain.com if you want hosted traces.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=multiagent-event-planner
